package openssl:component@0.1.0;

// Message digests (EVP_MD). Covers streaming and one-shot usage.

interface digest {
    use error.{code};

    enum algorithm {
        md5,
        sha1,
        sha224,
        sha256,
        sha384,
        sha512,
        sha512-224,
        sha512-256,
        sha3-224,
        sha3-256,
        sha3-384,
        sha3-512,
        shake128,
        shake256,
        blake2s-256,
        blake2b-512,
        ripemd160,
        sm3,
    }

    variant digest-error {
        unsupported-algorithm,
        xof-required,   // SHAKE* needs an explicit output length
        internal(code),
    }

    /// Fixed-length digest.
    one-shot: func(alg: algorithm, data: list<u8>) -> result<list<u8>, digest-error>;

    /// Extendable-output function (SHAKE128/256). Other algs error.
    one-shot-xof: func(alg: algorithm, data: list<u8>, out-len: u32)
        -> result<list<u8>, digest-error>;

    /// Output size in bytes for non-XOF algorithms.
    output-size: func(alg: algorithm) -> result<u32, digest-error>;

    /// Block size in bytes.
    block-size: func(alg: algorithm) -> result<u32, digest-error>;

    resource context {
        constructor(alg: algorithm);
        update: func(data: list<u8>) -> result<_, digest-error>;
        /// Finalize and return digest bytes. Consumes the context.
        finish: static func(ctx: context) -> result<list<u8>, digest-error>;
        /// Finalize XOF with a caller-chosen output length. Consumes.
        finish-xof: static func(ctx: context, out-len: u32)
            -> result<list<u8>, digest-error>;
        /// Deep-copy for mid-stream fork (e.g. TLS Finished computations).
        clone: func() -> context;
    }
}
