package openssl:component@0.1.0;

// Test-only interface for verifying the wit-bridge provider chain
// end-to-end. The host calls sign-with-wit-bridge(uri, mdname, tbs)
// and gets back the resulting signature (or a string error). The
// implementation:
//
//   1. OSSL_PROVIDER_load("wit-bridge") -- the bridge registered by
//      provider_wit.c at component init
//   2. Calls keymgmt.load(uri) via the wit-bridge to materialize an
//      EVP_PKEY whose private operations route back through the WIT
//   3. EVP_DigestSign over `tbs` using `mdname` as the hash algorithm
//   4. Returns the signature bytes
//
// Phase 6 will replace this with a proper SSLContext.set_pkcs11_key
// pathway exposed through the existing tls / pkey interfaces.
interface wit-bridge-test {
  sign-with-wit-bridge: func(
    uri: string,
    mdname: string,
    tbs: list<u8>,
  ) -> result<list<u8>, string>;

  /// Like sign-with-wit-bridge but routes through OpenSSL's EVP
  /// layer (EVP_PKEY_fromdata + EVP_PKEY_sign with manual prehash).
  /// Avoids EVP_DigestSign's m_sigver path.
  sign-via-evp-with-wit-bridge: func(
    uri: string,
    mdname: string,
    tbs: list<u8>,
  ) -> result<list<u8>, string>;

  /// EVP_DigestSign variant -- the exact path TLS uses. Phase 8a
  /// diagnostic for the open question from Phase 5.4: why does this
  /// path fail when the EVP_PKEY_sign + manual-prehash variant
  /// succeeds?
  digest-sign-via-evp-with-wit-bridge: func(
    uri: string,
    mdname: string,
    tbs: list<u8>,
  ) -> result<list<u8>, string>;

  /// Phase 8 STORE round-trip. Calls OSSL_STORE_open(uri), drains
  /// objects, returns counts. Validates the entire chain:
  /// openssl-wasm STORE dispatch -> pkcs11-store-adapter URI parse
  /// -> pkcs11:host find_objects walk -> bytes coming back.
  ///
  /// String error if OSSL_STORE_open itself fails (so the Rust test
  /// can distinguish "scheme not claimed" from "scheme claimed but
  /// token empty / no matching objects").
  record store-load-result {
    cert-count: u32,
    has-key:    bool,
    key-bits:   u32,
  }
  load-uri-test: func(uri: string) -> result<store-load-result, string>;

  /// Phase 8 ENCODER round-trip. Loads a wit-bridge-managed EVP_PKEY
  /// for `uri`, then runs OSSL_ENCODER_to_data with structure
  /// "SubjectPublicKeyInfo" + format "DER". Returns the SPKI bytes
  /// that the encoder chain produced, or a string error.
  ///
  /// Exercises the full pipeline: openssl encoder dispatch ->
  /// wit_encoder_encode (provider_wit) -> WIT encode method ->
  /// simple-provider-adapter -> tegmentum:key-backend.public-key-info
  /// -> bytes flow back through the OSSL_CORE_BIO -> BIO_write path.
  encode-spki-with-wit-bridge: func(uri: string) -> result<list<u8>, string>;

  /// Cross-provider encode test (#3): build an EC EVP_PKEY via the
  /// DEFAULT provider (no wit-bridge keymgmt involved), then ask the
  /// wit-bridge's encoder to emit SubjectPublicKeyInfo DER. Exercises
  /// the OSSL_FUNC_ENCODER_IMPORT_OBJECT path: framework exports the
  /// default-provider key's params, hands them to our import_object,
  /// then encode runs on the resulting WIT keydata.
  encode-spki-cross-provider: func() -> result<list<u8>, string>;

  /// Decoder round-trip test (#4). Calls the wit-bridge decoder
  /// directly on `spki` (skipping OpenSSL's decoder framework since
  /// we're testing the WIT contract, not OSSL plumbing), runs
  /// decoder.export-object on the resulting Keydata, then asks the
  /// wit-bridge encoder.import-object to re-assemble SPKI from the
  /// exported params. Returns the regenerated SPKI bytes.
  ///
  /// Exercises: decoder.decode (SPKI parse) + decoder.export-object
  /// (param emission) + encoder.import-object (SPKI rebuild). A
  /// successful round-trip means all three stages agree on the
  /// param shape.
  decode-spki-round-trip-with-wit-bridge: func(spki: list<u8>)
      -> result<list<u8>, string>;
}
